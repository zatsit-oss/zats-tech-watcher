---
import BlogIcon from "../assets/icons/blog.svg";
import LinkedInIcon from "../assets/icons/linkedin.svg";
import GitHubIcon from "../assets/icons/github.svg";

const year = new Date().getFullYear();
---

<footer class="glass border-t border-edge mt-auto py-6">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav class="flex flex-col sm:flex-row justify-center items-center gap-4 sm:gap-8 mb-4" aria-label="Liens sociaux">
      <div class="flex gap-3">
        <a href="https://blog.zatsit.fr/" target="_blank" rel="noopener noreferrer"
           aria-label="Notre blog (ouvre un nouvel onglet)"
           class="flex items-center justify-center h-11 w-11 rounded-full bg-primary text-white hover:opacity-80 transition-opacity">
          <BlogIcon class="w-4 h-4" aria-hidden="true" />
        </a>
        <a href="https://www.linkedin.com/company/zatsit/" target="_blank" rel="noopener noreferrer"
           aria-label="Notre page LinkedIn (ouvre un nouvel onglet)"
           class="flex items-center justify-center h-11 w-11 rounded-full bg-primary text-white hover:opacity-80 transition-opacity">
          <LinkedInIcon class="w-4 h-4" aria-hidden="true" />
        </a>
        <a href="https://github.com/zatsit-oss" target="_blank" rel="noopener noreferrer"
           aria-label="Notre GitHub (ouvre un nouvel onglet)"
           class="flex items-center justify-center h-11 w-11 rounded-full bg-primary text-white hover:opacity-80 transition-opacity">
          <GitHubIcon class="w-4 h-4" aria-hidden="true" />
        </a>
      </div>
    </nav>
    <div class="text-center text-sm text-content-muted">
      <p><strong>zatsit</strong> Tech Watch - Veille technologique collaborative</p>
      <p class="mt-1">&copy; {year} <strong>zatsit</strong>. Tous droits réservés.</p>
      <p class="mt-1 text-xs">
        Propulsé par <a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="hover:text-primary underline">Astro</a>,
        hébergé en France chez <a href="https://www.clever-cloud.com" target="_blank" rel="noopener noreferrer" class="hover:text-primary underline">Clever Cloud</a>
        · <a href="/mentions-legales/" class="hover:text-primary underline">Mentions légales</a>
      </p>
    </div>
  </div>
</footer>
