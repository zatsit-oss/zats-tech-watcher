---
import Layout from "../layouts/Layout.astro";
import { loadEntries } from "../data/load-entries.ts";
import { groupByDate, monthKey, monthLabel, weekKey } from "../utils/date.ts";
import { renderTagBadge } from "../components/tag-badge.ts";
import { renderContributorName } from "../components/contributor-name.ts";
import { escapeHtml } from "../utils/format.ts";
import type { TechWatchEntry } from "../types.ts";

const entries = loadEntries();
const sorted = [...entries].sort((a, b) => b.date.getTime() - a.date.getTime());

// Pre-render both views
const monthGroups = groupByDate(sorted, (e) => e.date, monthKey);
const weekGroups = groupByDate(sorted, (e) => e.date, weekKey);

function renderEntry(entry: TechWatchEntry): string {
  return `
    <div class="glass rounded-lg p-3 glass-hover transition-all duration-200">
      <div class="flex items-start justify-between gap-2 mb-1">
        <a href="${escapeHtml(entry.url)}" target="_blank" rel="noopener noreferrer" class="text-sm font-medium text-content hover:text-primary transition-colors">
          ${escapeHtml(entry.subject)}
        </a>
        <span class="text-xs text-content-muted shrink-0">${escapeHtml(entry.dateStr)}</span>
      </div>
      <div class="flex items-center gap-2 flex-wrap">
        ${renderContributorName(entry.contributor)}
        <span class="text-xs text-content-muted">·</span>
        <span class="text-xs text-content-muted">${escapeHtml(entry.domain)}</span>
        <span class="text-xs text-content-muted">·</span>
        <div class="flex gap-1">${entry.tags.map((t) => renderTagBadge(t, false, false)).join("")}</div>
      </div>
    </div>
  `;
}

function renderGroupHtml(key: string, items: TechWatchEntry[], mode: string): string {
  const label = mode === "month" ? monthLabel(items[0].date) : key;
  return `
    <div class="relative pl-12 pb-8">
      <div class="absolute left-2.5 top-1 w-4 h-4 rounded-full bg-primary border-4 border-bg"></div>
      <div class="mb-3">
        <h2 class="text-lg font-bold text-content">${label}</h2>
        <span class="text-xs text-content-muted">${items.length} entrée${items.length > 1 ? "s" : ""}</span>
      </div>
      <div class="space-y-2">
        ${items.map(renderEntry).join("")}
      </div>
    </div>
  `;
}

const monthSortedKeys = Array.from(monthGroups.keys()).sort().reverse();
const weekSortedKeys = Array.from(weekGroups.keys()).sort().reverse();
const monthHtml = monthSortedKeys.map(k => renderGroupHtml(k, monthGroups.get(k)!, "month")).join("");
const weekHtml = weekSortedKeys.map(k => renderGroupHtml(k, weekGroups.get(k)!, "week")).join("");
---

<Layout title="Timeline — Zatsit Tech Watch">
  <div class="page-enter">
    <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 mb-8">
      <div>
        <h1 class="text-3xl font-bold gradient-text mb-2">Timeline</h1>
        <p class="text-content-muted text-sm">Vue chronologique des contributions</p>
      </div>
      <div class="flex items-center gap-1 glass rounded-lg p-1">
        <button data-mode="month" class="timeline-mode-btn px-3 py-1.5 rounded-md text-sm transition-colors bg-primary text-white" aria-pressed="true">Mois</button>
        <button data-mode="week" class="timeline-mode-btn px-3 py-1.5 rounded-md text-sm transition-colors text-content-muted hover:text-content" aria-pressed="false">Semaine</button>
      </div>
    </div>

    <div class="relative">
      <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-edge-solid"></div>
      <div id="timeline-month" set:html={monthHtml} />
      <div id="timeline-week" class="hidden" set:html={weekHtml} />
    </div>
  </div>
</Layout>

<script>
  document.querySelectorAll('.timeline-mode-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      const mode = (btn as HTMLElement).dataset.mode;
      const monthEl = document.getElementById('timeline-month')!;
      const weekEl = document.getElementById('timeline-week')!;

      monthEl.classList.toggle('hidden', mode !== 'month');
      weekEl.classList.toggle('hidden', mode !== 'week');

      document.querySelectorAll('.timeline-mode-btn').forEach(b => {
        const isActive = (b as HTMLElement).dataset.mode === mode;
        b.classList.toggle('bg-primary', isActive);
        b.classList.toggle('text-white', isActive);
        b.classList.toggle('text-content-muted', !isActive);
        b.setAttribute('aria-pressed', String(isActive));
      });
    });
  });
</script>
