---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Page introuvable — Zatsit Tech Watch" description="Erreur 404 — page introuvable">
  <div class="page-enter flex flex-col items-center justify-center text-center py-24">
    <p class="text-7xl font-bold gradient-text mb-4" aria-hidden="true">404</p>
    <h1 class="text-2xl font-bold text-content mb-2">Page introuvable</h1>
    <p class="text-content-muted text-sm mb-8">La page que vous cherchez n'existe pas ou a été déplacée.</p>
    <a href="/" class="inline-flex items-center justify-center gap-2 px-4 py-2.5 rounded-lg bg-primary text-white text-sm font-medium hover:opacity-90 transition-opacity">
      Retour à l'accueil
    </a>
  </div>
</Layout>
