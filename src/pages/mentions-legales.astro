---
import Layout from "../layouts/Layout.astro";
import { siteConfig } from "../config.ts";
---

<Layout title="Mentions légales - Zatsit Tech Watch" description="Mentions légales du portail de veille technologique Zatsit">
  <div class="page-enter max-w-3xl">
    <h1 class="text-3xl font-bold gradient-text mb-8">Mentions légales</h1>

    <section class="glass rounded-xl p-6 mb-6">
      <h2 class="text-lg font-semibold text-content mb-3">Éditeur de la plateforme</h2>
      <p class="text-sm text-content leading-relaxed">
        <strong>zatsit</strong>, SAS au capital de 10 000,00 €, immatriculée au Registre du
        Commerce et des Sociétés de Lille sous le numéro 979 488 822.<br />
        Son siège social se situe au 2 allée de la Haye du temple, 59160 Lomme.<br />
        Pour nous contacter : <a href="mailto:support@zatsit.fr" class="text-primary hover:underline">support@zatsit.fr</a>
      </p>
    </section>

    <section class="glass rounded-xl p-6 mb-6">
      <h2 class="text-lg font-semibold text-content mb-3">Directeur de la publication</h2>
      <p class="text-sm text-content leading-relaxed">
        Emmanuel Péru, Directeur Technique <strong>zatsit</strong>.
      </p>
    </section>

    <section class="glass rounded-xl p-6 mb-6">
      <h2 class="text-lg font-semibold text-content mb-3">Hébergement de la plateforme</h2>
      <p class="text-sm text-content leading-relaxed">
        Le site est hébergé dans un datacenter en France, géré par la société
        <strong>Clever Cloud</strong>, SAS au capital de 22 952 €, immatriculée au Registre du
        Commerce et des Sociétés de Nantes sous le numéro B 524 172 699, dont le siège social
        est situé au 4 rue Voltaire, 44000 Nantes, France.<br />
        Numéro de TVA intracommunautaire : FR 87 524 172 699<br />
        Contact : <a href="https://www.clever-cloud.com" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">www.clever-cloud.com</a>
      </p>
    </section>

    <section class="glass rounded-xl p-6 mb-6">
      <h2 class="text-lg font-semibold text-content mb-3">Données personnelles</h2>
      <p class="text-sm text-content leading-relaxed">
        {siteConfig.anonymizeContributors
          ? "Les contributions de veille sont publiées de manière anonymisée : les auteurs sont désignés par des pseudonymes."
          : "Ce site affiche les prénoms et initiales des consultants zatsit contributeurs de la veille technologique, dans le cadre de leur activité professionnelle."}
        Aucune {siteConfig.anonymizeContributors ? "" : "autre "}donnée personnelle n'est
        collectée par ce site : pas de compte utilisateur, pas de cookie de suivi, pas de
        mesure d'audience. Pour toute demande de rectification ou de suppression, contactez
        <a href="mailto:support@zatsit.fr" class="text-primary hover:underline">support@zatsit.fr</a>.
      </p>
    </section>

    <section class="glass rounded-xl p-6">
      <h2 class="text-lg font-semibold text-content mb-3">Propriété intellectuelle</h2>
      <p class="text-sm text-content leading-relaxed">
        Le code source de ce site est publié sous licence MIT sur
        <a href="https://github.com/zatsit-oss/zats-tech-watcher" target="_blank" rel="noopener noreferrer" class="text-primary hover:underline">GitHub</a>.
        Les articles référencés restent la propriété de leurs auteurs et éditeurs respectifs ;
        les liens renvoient vers les sources originales.
      </p>
    </section>
  </div>
</Layout>
